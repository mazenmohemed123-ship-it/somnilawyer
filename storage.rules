rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile avatars — publicly viewable (shown on the client portal before
    // login), but only the owner can upload to their own folder.
    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Case documents (Vault tab) — office members only.
    match /documents/{ownerId}/{caseId}/{fileName} {
      allow read, write: if request.auth != null
        && (request.auth.uid == ownerId ||
            (firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
             firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.master_lawyer_id == ownerId));
    }

    // Chat attachments — conversation ids are unguessable, any signed-in
    // user (including anonymous clients) may read/write, matching the
    // Firestore rules for /conversations/{id}.
    match /chat-attachments/{conversationId}/{fileName} {
      allow read, write: if request.auth != null;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
