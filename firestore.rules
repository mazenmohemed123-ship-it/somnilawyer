rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function isAdminUser() {
      return isAuth() && request.auth.token.email == 'mazenmohemed123@gmail.com';
    }

    // Get user role safely (returns 'unknown' if user doesn't exist)
    function getUserRole() {
      let userRef = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userRef) ? get(userRef).data.role : 'unknown';
    }

    function isLawyer() {
      let role = getUserRole();
      return isAuth() && role in ['owner', 'partner', 'lawyer', 'assistant', 'secretary', 'accountant'];
    }

    function isCaseLawyer(caseId) {
      let caseRef = /databases/$(database)/documents/cases/$(caseId);
      if (!exists(caseRef)) return false;
      let caseData = get(caseRef).data;
      return isAuth() && (
        request.auth.uid == caseData.lawyer_id ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.master_lawyer_id == caseData.lawyer_id)
      );
    }

    function isConversationParticipant(convId) {
      let convRef = /databases/$(database)/documents/conversations/$(convId);
      if (!exists(convRef)) return false;
      let convData = get(convRef).data;
      return isAuth() && convData.participants.hasAny([request.auth.uid]);
    }

    // ===== USERS COLLECTION =====
    match /users/{userId} {
      // Users can read and write their own profile
      allow read: if isOwner(userId) || isAdminUser();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdminUser();
      allow delete: if isAdminUser();
    }

    // ===== CASES COLLECTION =====
    match /cases/{caseId} {
      allow read: if isAuth() && (
        isCaseLawyer(caseId) ||
        isAdminUser()
      );
      allow create: if isAuth() && (
        isLawyer() ||
        isAdminUser()
      );
      allow update: if isAuth() && (
        isCaseLawyer(caseId) ||
        isAdminUser()
      );
      allow delete: if isAdminUser();

      // Case events subcollection
      match /events/{eventId} {
        allow read: if isAuth() && (
          isCaseLawyer(caseId) ||
          isAdminUser()
        );
        allow create: if isAuth() && (
          isCaseLawyer(caseId) ||
          isAdminUser()
        );
        allow update, delete: if false;
      }
    }

    // ===== CONVERSATIONS COLLECTION =====
    match /conversations/{convId} {
      // Anyone authenticated can read conversations they're part of
      allow read: if isAuth() && isConversationParticipant(convId);
      // Anyone authenticated can create conversations
      allow create: if isAuth();
      // Only participants can update
      allow update: if isAuth() && isConversationParticipant(convId);
      allow delete: if false;

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isAuth() && isConversationParticipant(convId);
        allow create: if isAuth() && (
          isConversationParticipant(convId) &&
          request.resource.data.sender_id == request.auth.uid
        );
        allow update: if isAuth() && (
          isConversationParticipant(convId) &&
          resource.data.sender_id == request.auth.uid
        );
        allow delete: if false;
      }
    }

    // ===== APPOINTMENTS COLLECTION =====
    match /appointments/{appointmentId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.lawyer_id ||
        request.auth.uid == resource.data.client_id ||
        isAdminUser()
      );
      allow create: if isAuth();
      allow update: if isAuth() && (
        request.auth.uid == resource.data.lawyer_id ||
        isAdminUser()
      );
      allow delete: if isAdminUser();
    }

    // ===== AVAILABILITY COLLECTION =====
    match /availability/{lawyerId} {
      allow read: if true; // Public read
      allow write: if isOwner(lawyerId) || isAdminUser();
    }

    // ===== PAYMENTS COLLECTION =====
    match /payments/{paymentId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.user_id ||
        isAdminUser()
      );
      allow create: if isAdminUser();
      allow update: if isAdminUser();
      allow delete: if false;
    }

    // ===== ORDERS COLLECTION =====
    match /orders/{orderId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.user_id ||
        isAdminUser()
      );
      allow create: if isAdminUser();
      allow update: if isAdminUser();
      allow delete: if false;
    }

    // ===== COUPONS COLLECTION =====
    match /coupons/{couponId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdminUser();
    }

    // ===== ANNOUNCEMENTS COLLECTION =====
    match /announcements/{announcementId} {
      allow read: if true; // Public read
      allow create, update, delete: if isAdminUser();
    }

    // ===== VAULT COLLECTION =====
    match /vault/{lawyerId}/documents/{documentId} {
      allow read: if isAuth() && (
        isOwner(lawyerId) ||
        (isLawyer() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.master_lawyer_id == lawyerId)
      );
      allow create, update, delete: if isOwner(lawyerId) || isAdminUser();
    }

    // ===== AI USAGE COLLECTION =====
    match /ai_usage/{usageId} {
      allow read: if isAuth() && request.auth.uid == resource.data.user_id;
      allow create, update: if false; // Created by Cloud Functions
      allow delete: if false;
    }

    // ===== CASE EMERGENCIES COLLECTION =====
    match /case_emergencies/{emergencyId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.lawyer_id ||
        request.auth.uid == resource.data.client_id ||
        isAdminUser()
      );
      allow create: if isAuth();
      allow update, delete: if isAdminUser();
    }

    // ===== DEFAULT DENY =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

