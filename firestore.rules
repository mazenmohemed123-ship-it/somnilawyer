rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuth() && getUserRole() == 'admin';
    }

    function isLawyer() {
      return isAuth() && (getUserRole() == 'lawyer' || getUserRole() == 'team_member' || getUserRole() == 'owner');
    }

    function isCaseLawyer(caseId) {
      let caseData = get(/databases/$(database)/documents/cases/$(caseId)).data;
      return isAuth() && (request.auth.uid == caseData.lawyer_id ||
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.master_lawyer_id == caseData.lawyer_id);
    }

    function isConversationParticipant(convId) {
      let convData = get(/databases/$(database)/documents/conversations/$(convId)).data;
      return isAuth() && convData.participants.hasAny([request.auth.uid]);
    }

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.role in ['owner', 'client', 'team_member'];
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Cases collection
    match /cases/{caseId} {
      allow read: if isAuth() && (
        isCaseLawyer(caseId) ||
        isAdmin() ||
        request.auth.uid == resource.data.client_id
      );
      allow create: if isLawyer() && request.resource.data.lawyer_id == request.auth.uid;
      allow update: if isCaseLawyer(caseId) || isAdmin();
      allow delete: if isCaseLawyer(caseId) || isAdmin();

      // Case events subcollection
      match /events/{eventId} {
        allow read: if isCaseLawyer(caseId) || isAdmin();
        allow create: if isCaseLawyer(caseId);
        allow update, delete: if false;
      }
    }

    // Conversations collection
    match /conversations/{convId} {
      allow read: if isConversationParticipant(convId);
      allow create: if isAuth();
      allow update: if isConversationParticipant(convId);
      allow delete: if false;

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isConversationParticipant(convId);
        allow create: if isConversationParticipant(convId) && request.resource.data.sender_id == request.auth.uid;
        allow update: if isConversationParticipant(convId) && resource.data.sender_id == request.auth.uid;
        allow delete: if false;
      }
    }

    // Appointments collection
    match /appointments/{appointmentId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.lawyer_id ||
        request.auth.uid == resource.data.client_id ||
        isAdmin()
      );
      allow create: if isAuth() && (
        request.auth.uid == request.resource.data.client_id ||
        (isLawyer() && request.auth.uid == request.resource.data.lawyer_id)
      );
      allow update: if isAuth() && (
        request.auth.uid == resource.data.lawyer_id || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Availability collection
    match /availability/{lawyerId} {
      allow read: if true; // Public read for scheduling
      allow write: if isOwner(lawyerId) || isAdmin();
    }

    // Payments collection
    match /payments/{paymentId} {
      allow read: if isOwner(resource.data.user_id) || isAdmin();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // Orders collection (for Paymob tracking)
    match /orders/{orderId} {
      allow read: if isOwner(resource.data.user_id) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Coupons collection
    match /coupons/{couponId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Announcements collection
    match /announcements/{announcementId} {
      allow read: if true; // Public read
      allow create, update, delete: if isAdmin();
    }

    // Vault documents
    match /vault/{lawyerId}/documents/{documentId} {
      allow read: if isOwner(lawyerId) ||
        (isLawyer() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.master_lawyer_id == lawyerId);
      allow create, update, delete: if isOwner(lawyerId) || isAdmin();
    }

    // AI usage tracking
    match /ai_usage/{usageId} {
      allow read: if isOwner(resource.data.user_id) || isAdmin();
      allow create, update: if false; // Created by Cloud Functions
      allow delete: if false;
    }

    // Case emergencies
    match /case_emergencies/{emergencyId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.lawyer_id ||
        request.auth.uid == resource.data.client_id ||
        isAdmin()
      );
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
