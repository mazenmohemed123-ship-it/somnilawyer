rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Admin check by email only — never touches Firestore to avoid bootstrap issues
    function isAdminUser() {
      return isAuth() && request.auth.token.email == 'mazenmohemed123@gmail.com';
    }

    // Safe role lookup — returns 'unknown' if the user document does not exist yet
    function getUserRole() {
      let userRef = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userRef) ? get(userRef).data.role : 'unknown';
    }

    function isLawyer() {
      let role = getUserRole();
      return isAuth() && role in ['owner', 'partner', 'lawyer', 'assistant', 'secretary', 'accountant'];
    }

    function isCaseLawyer(caseId) {
      let caseRef = /databases/$(database)/documents/cases/$(caseId);
      let lawyerId = exists(caseRef) ? get(caseRef).data.lawyer_id : '';
      let userRef = /databases/$(database)/documents/users/$(request.auth.uid);
      let masterLawyerId = exists(userRef) ? get(userRef).data.master_lawyer_id : '';
      return isAuth() && (
        request.auth.uid == lawyerId ||
        masterLawyerId == lawyerId
      );
    }

    function isConversationParticipant(convId) {
      let convRef = /databases/$(database)/documents/conversations/$(convId);
      let participants = exists(convRef) ? get(convRef).data.participants : [];
      return isAuth() && participants.hasAny([request.auth.uid]);
    }

    // ===== USERS =====
    // Lawyers need to be readable by authenticated clients (anonymously signed in)
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdminUser() || isAuth();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdminUser();
      allow delete: if isAdminUser();
    }

    // ===== CASES =====
    // Any authenticated user (including anonymous portal visitors) can read cases.
    // The client portal needs to query cases by lawyer_id to verify the phone number.
    // Write operations are still strictly controlled.
    match /cases/{caseId} {
      allow read: if isAuth();
      allow create: if isAuth() && (isLawyer() || isAdminUser());
      allow update: if isAuth() && (isCaseLawyer(caseId) || isAdminUser());
      allow delete: if isAdminUser();

      match /events/{eventId} {
        allow read: if isAuth() && (isCaseLawyer(caseId) || isAdminUser());
        allow create: if isAuth() && (isCaseLawyer(caseId) || isAdminUser());
        allow update, delete: if false;
      }
    }

    // ===== CONVERSATIONS =====
    // Conversation IDs are unguessable (case__{firestore-auto-id} / sorted uids),
    // so any authenticated user may read/write. This is required because a party
    // must read the shared conversation before it can add itself to participants.
    match /conversations/{convId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isAuth();
        allow create: if isAuth() && request.resource.data.sender_id == request.auth.uid;
        allow update: if isAuth() && resource.data.sender_id == request.auth.uid;
        allow delete: if false;
      }
    }

    // ===== APPOINTMENTS =====
    match /appointments/{appointmentId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.lawyer_id ||
        request.auth.uid == resource.data.client_id ||
        isAdminUser()
      );
      allow create: if isAuth();
      allow update: if isAuth() && (
        request.auth.uid == resource.data.lawyer_id || isAdminUser()
      );
      allow delete: if isAdminUser();
    }

    // ===== AVAILABILITY (public read for booking) =====
    match /availability/{lawyerId} {
      allow read: if true;
      allow write: if isOwner(lawyerId) || isAdminUser();
    }

    // ===== PAYMENTS =====
    match /payments/{paymentId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.user_id || isAdminUser()
      );
      allow create, update: if isAdminUser();
      allow delete: if false;
    }

    // ===== ORDERS =====
    match /orders/{orderId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.user_id || isAdminUser()
      );
      allow create, update: if isAdminUser();
      allow delete: if false;
    }

    // ===== COUPONS =====
    match /coupons/{couponId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdminUser();
    }

    // ===== ANNOUNCEMENTS (public read) =====
    match /announcements/{announcementId} {
      allow read: if true;
      allow create, update, delete: if isAdminUser();
    }

    // ===== VAULT (nested path) =====
    match /vault/{lawyerId}/documents/{documentId} {
      allow read: if isAuth() && (
        isOwner(lawyerId) ||
        (isLawyer() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.master_lawyer_id == lawyerId)
      );
      allow create, update, delete: if isOwner(lawyerId) || isAdminUser();
    }

    // ===== DOCUMENTS (flat collection used by VaultTab) =====
    match /documents/{documentId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.lawyer_id ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.master_lawyer_id == resource.data.lawyer_id) ||
        isAdminUser()
      );
      allow create: if isAuth() && (isLawyer() || isAdminUser());
      allow update, delete: if isAuth() && (
        request.auth.uid == resource.data.lawyer_id || isAdminUser()
      );
    }

    // ===== AI USAGE =====
    match /ai_usage/{usageId} {
      allow read: if isAuth() && request.auth.uid == resource.data.user_id;
      allow create, update, delete: if false;
    }

    // ===== CASE EMERGENCIES =====
    match /case_emergencies/{emergencyId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.lawyer_id ||
        request.auth.uid == resource.data.client_id ||
        isAdminUser()
      );
      allow create: if isAuth();
      allow update, delete: if isAdminUser();
    }

    // ===== CASE EVENTS (appointment history) =====
    match /case_events/{eventId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.lawyer_id || isAdminUser()
      );
      allow create: if isAuth() && (isLawyer() || isAdminUser());
      allow update, delete: if false;
    }

    // Default deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
